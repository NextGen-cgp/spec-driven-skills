{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/sdd/security-permissions-review.schema.json",
  "title": "SDD Security Permissions Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "feature_id",
    "review_type",
    "status",
    "reviewed_artifacts",
    "scope",
    "roles",
    "operations",
    "findings",
    "required_controls",
    "required_tests",
    "routing_decision"
  ],
  "properties": {
    "feature_id": {
      "type": "string",
      "minLength": 1
    },
    "review_type": {
      "type": "string",
      "enum": [
        "pre_spec_validation",
        "post_implementation",
        "post_test",
        "final_gate"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "SECURITY_APPROVED",
        "SECURITY_APPROVED_WITH_WARNINGS",
        "SECURITY_CHANGES_REQUIRED",
        "SECURITY_BLOCKED",
        "NOT_APPLICABLE",
        "BLOCKED_BY_AMBIGUITY"
      ]
    },
    "reviewed_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "object",
      "required": [
        "affects_auth",
        "affects_roles",
        "affects_api",
        "affects_data",
        "affects_state_transitions"
      ],
      "properties": {
        "affects_auth": {
          "type": "boolean"
        },
        "affects_roles": {
          "type": "boolean"
        },
        "affects_api": {
          "type": "boolean"
        },
        "affects_data": {
          "type": "boolean"
        },
        "affects_state_transitions": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "allowed_roles",
          "backend_enforcement_required"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "read",
              "create",
              "update",
              "delete",
              "transition",
              "search",
              "export",
              "import",
              "admin",
              "other"
            ]
          },
          "allowed_roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "denied_roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "backend_enforcement_required": {
            "type": "boolean"
          },
          "endpoint_or_action": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "title",
          "description",
          "affected_area",
          "blocking",
          "recommended_action"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "CRITICAL",
              "HIGH",
              "MEDIUM",
              "LOW",
              "INFO"
            ]
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "affected_area": {
            "type": "string",
            "enum": [
              "auth",
              "authorization",
              "api",
              "frontend",
              "backend",
              "database",
              "data_exposure",
              "state_transition",
              "validation",
              "audit",
              "other"
            ]
          },
          "blocking": {
            "type": "boolean"
          },
          "traceability": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommended_action": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "required_controls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "routing_decision": {
      "type": "object",
      "required": [
        "next_skill",
        "reason"
      ],
      "properties": {
        "next_skill": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "blocked": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  }
}
